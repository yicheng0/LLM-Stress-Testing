# Backend
# SQLite is the default lightweight state store for local web-console use.
DATABASE_URL=sqlite:///./data/llm_test.db
RESULTS_DIR=./results
MAX_RUNNING_TESTS=2
MAX_CONCURRENCY_PER_TEST=500

# Frontend
# Leave empty in local Vite development to use vite.config.js proxy rules.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# Secrets
# Do not store real API keys here. Enter API keys per test run in the UI,
# or pass them via shell variables for CLI commands.
# API_KEY=
