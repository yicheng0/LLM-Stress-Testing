# Backend
# PostgreSQL is the default backend state store for deployment use.
DATABASE_URL=postgresql+psycopg://llm_test:llm_test@postgres:5432/llm_test
RESULTS_DIR=./results
MAX_RUNNING_TESTS=2
MAX_CONCURRENCY_PER_TEST=500
RESULT_RETENTION_HOURS=24
CLEANUP_ON_STARTUP=true
CLEANUP_INTERVAL_MINUTES=60
SELF_UPDATE_ENABLED=true
SELF_UPDATE_COMMAND=sh /app/scripts/docker-self-update.sh
SELF_UPDATE_TIMEOUT_SEC=900
POSTGRES_DB=llm_test
POSTGRES_USER=llm_test
POSTGRES_PASSWORD=llm_test
POSTGRES_PORT=5432
WEB_PORT=8080
BACKEND_PORT=8081

# Frontend
# Leave empty in local Vite development to use vite.config.js proxy rules.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# Secrets
# Do not store real API keys here. Enter API keys per test run in the UI,
# or pass them via shell variables for CLI commands.
# API_KEY=
